#. Welcome wizard
#: src/ui/welcome_wizard.rs
msgid "Welcome to Speech to Text"
msgstr "Bienvenido a Voz a Texto"

#: src/ui/welcome_wizard.rs
msgid "Next"
msgstr "Siguiente"

#: src/ui/welcome_wizard.rs
msgid "Get Started"
msgstr "Comenzar"

#: src/ui/welcome_wizard.rs
msgid ""
"Convert speech to text locally on your machine.\n"
"No internet connection required after initial setup."
msgstr ""
"Convierta voz a texto localmente.\n"
"No se requiere conexión a Internet después de la configuración."

#: src/ui/welcome_wizard.rs
msgid "100% offline — your audio never leaves your device"
msgstr "100% sin conexión — su audio nunca sale de su dispositivo"

#: src/ui/welcome_wizard.rs
msgid "Supports 99 languages with auto-detection"
msgstr "Compatible con 99 idiomas con detección automática"

#: src/ui/welcome_wizard.rs
msgid "Download a Whisper Model"
msgstr "Descargar un modelo Whisper"

#: src/ui/welcome_wizard.rs
msgid ""
"A language model is needed for transcription.\n"
"We recommend starting with the Tiny model (~75 MB)."
msgstr ""
"Se necesita un modelo para la transcripción.\n"
"Recomendamos el modelo Tiny (~75 MB)."

#: src/ui/welcome_wizard.rs
msgid "Download Model"
msgstr "Descargar modelo"

#: src/ui/welcome_wizard.rs
msgid "Downloading…"
msgstr "Descargando…"

#: src/ui/welcome_wizard.rs
msgid "Retry"
msgstr "Reintentar"

#: src/ui/welcome_wizard.rs
msgid "You're All Set!"
msgstr "¡Todo listo!"

#: src/ui/welcome_wizard.rs
msgid "Download complete!"
msgstr "¡Descarga completada!"

#. Settings — Language
#: src/ui/settings/language.rs
msgid "Language Detection"
msgstr "Detección de idioma"

#: src/ui/settings/language.rs
msgid "Whisper can automatically detect the spoken language"
msgstr "Whisper puede detectar automáticamente el idioma hablado"

#: src/ui/settings/language.rs
msgid "Auto-detect Language"
msgstr "Detectar idioma automáticamente"

#: src/ui/settings/language.rs
msgid "Let Whisper determine the language automatically"
msgstr "Dejar que Whisper determine el idioma automáticamente"

#: src/ui/settings/language.rs
msgid "Manual Selection"
msgstr "Selección manual"

#: src/ui/settings/language.rs
msgid "Force a specific language for transcription"
msgstr "Forzar un idioma específico para la transcripción"

#: src/ui/settings/language.rs
msgid "Used when auto-detect is disabled"
msgstr "Se usa cuando la detección automática está desactivada"

#: src/ui/settings/language.rs
msgid "Supported Languages"
msgstr "Idiomas compatibles"

#: src/ui/settings/language.rs
msgid "Translation"
msgstr "Traducción"

#: src/ui/settings/language.rs
msgid "Whisper can also translate speech to English"
msgstr "Whisper también puede traducir voz al inglés"

#. Settings — Microphone
#: src/ui/settings/microphone.rs
msgid "Input Device"
msgstr "Dispositivo de entrada"

#: src/ui/settings/microphone.rs
msgid "Select the microphone to use for recording"
msgstr "Seleccione el micrófono a utilizar"

#: src/ui/settings/microphone.rs
msgid "Refresh device list"
msgstr "Actualizar lista de dispositivos"

#: src/ui/settings/microphone.rs
msgid "Audio Settings"
msgstr "Configuración de audio"

#: src/ui/settings/microphone.rs
msgid "Sample Rate"
msgstr "Frecuencia de muestreo"

#: src/ui/settings/microphone.rs
msgid "Audio will be resampled to 16kHz for Whisper"
msgstr "El audio se remuestreará a 16 kHz para Whisper"

#: src/ui/settings/microphone.rs
msgid "Channels"
msgstr "Canales"

#: src/ui/settings/microphone.rs
msgid "Stereo input is automatically converted to mono"
msgstr "La entrada estéreo se convierte automáticamente a mono"

#: src/ui/settings/microphone.rs
msgid "Mono"
msgstr "Mono"

#: src/ui/settings/microphone.rs
msgid "Microphone Test"
msgstr "Prueba de micrófono"

#: src/ui/settings/microphone.rs
msgid "Test Microphone"
msgstr "Probar micrófono"

#: src/ui/settings/microphone.rs
msgid "Record a short sample to verify your microphone works"
msgstr "Grabe una muestra corta para verificar su micrófono"

#: src/ui/settings/microphone.rs
msgid "Test"
msgstr "Probar"

#: src/ui/settings/microphone.rs
msgid "No audio input devices found"
msgstr "No se encontraron dispositivos de audio"

#: src/ui/settings/microphone.rs
msgid "Check that a microphone is connected"
msgstr "Verifique que un micrófono esté conectado"

#. Settings — Model
#: src/ui/settings/model.rs
msgid "Whisper Models"
msgstr "Modelos Whisper"

#: src/ui/settings/model.rs
msgid "Select a model. Larger models are more accurate but slower."
msgstr ""
"Seleccione un modelo. Los más grandes son más precisos pero más lentos."

#: src/ui/settings/model.rs
msgid "Downloaded"
msgstr "Descargado"

#: src/ui/settings/model.rs
msgid "Download"
msgstr "Descargar"

#: src/ui/settings/model.rs
msgid "Download Progress"
msgstr "Progreso de descarga"

#: src/ui/settings/model.rs
msgid "No download in progress"
msgstr "Sin descarga en curso"

#: src/ui/settings/model.rs
msgid "Storage"
msgstr "Almacenamiento"

#: src/ui/settings/model.rs
msgid "Choose where Whisper models are stored."
msgstr "Elija dónde almacenar los modelos Whisper."

#: src/ui/settings/model.rs
msgid "Models Directory"
msgstr "Directorio de modelos"

#: src/ui/settings/model.rs
msgid "Open in file manager"
msgstr "Abrir en gestor de archivos"

#: src/ui/settings/model.rs
msgid "Change models directory"
msgstr "Cambiar directorio de modelos"

#: src/ui/settings/model.rs
msgid "Select Models Directory"
msgstr "Seleccionar directorio de modelos"

#: src/ui/settings/model.rs
msgid "Reset to default location"
msgstr "Restablecer ubicación predeterminada"

#. Settings — Performance
#: src/ui/settings/performance.rs
msgid "GPU Acceleration"
msgstr "Aceleración GPU"

#: src/ui/settings/performance.rs
msgid ""
"Use GPU for faster transcription when available. Requires CUDA or OpenCL "
"support."
msgstr "Usar GPU para transcripción más rápida. Requiere CUDA o OpenCL."

#: src/ui/settings/performance.rs
msgid "Use GPU"
msgstr "Usar GPU"

#: src/ui/settings/performance.rs
msgid "Accelerate transcription with your graphics card"
msgstr "Acelerar la transcripción con su tarjeta gráfica"

#: src/ui/settings/performance.rs
msgid "CPU Fallback"
msgstr "Respaldo CPU"

#: src/ui/settings/performance.rs
msgid "Automatically fall back to CPU if GPU is unavailable"
msgstr "Cambiar automáticamente a CPU si la GPU no está disponible"

#: src/ui/settings/performance.rs
msgid "GPU Status"
msgstr "Estado de GPU"

#: src/ui/settings/performance.rs
msgid "CPU Settings"
msgstr "Configuración de CPU"

#: src/ui/settings/performance.rs
msgid "Worker Threads"
msgstr "Hilos de trabajo"

#: src/ui/settings/performance.rs
msgid "Number of CPU threads for transcription"
msgstr "Número de hilos de CPU para la transcripción"

#: src/ui/settings/performance.rs
msgid "Memory"
msgstr "Memoria"

#: src/ui/settings/performance.rs
msgid "Estimated Memory Usage"
msgstr "Uso de memoria estimado"

#: src/ui/settings/performance.rs
msgid "Depends on the selected model size"
msgstr "Depende del tamaño del modelo seleccionado"

#: src/ui/settings/performance.rs
msgid "Beam Size"
msgstr "Tamaño del haz"

#: src/ui/settings/performance.rs
msgid "Higher values improve accuracy but use more memory"
msgstr "Valores más altos mejoran la precisión pero usan más memoria"

