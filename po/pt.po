#: src/ui/settings/performance.rs
msgid "Estimated Memory Usage"
msgstr "Uso de memória estimado"

#: src/ui/settings/performance.rs
msgid "Depends on the selected model size"
msgstr "Depende do tamanho do modelo selecionado"

#: src/ui/settings/performance.rs
msgid "Beam Size"
msgstr "Tamanho do beam"

#: src/ui/settings/performance.rs
msgid "Higher values improve accuracy but use more memory"
msgstr "Valores mais altos melhoram a precisão, mas usam mais memória"

