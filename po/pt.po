#. Welcome wizard
#: src/ui/welcome_wizard.rs
msgid "Welcome to Speech to Text"
msgstr "Bem-vindo ao Voz para Texto"

#: src/ui/welcome_wizard.rs
msgid "Next"
msgstr "Próximo"

#: src/ui/welcome_wizard.rs
msgid "Get Started"
msgstr "Começar"

#: src/ui/welcome_wizard.rs
msgid ""
"Convert speech to text locally on your machine.\n"
"No internet connection required after initial setup."
msgstr ""
"Converta voz em texto localmente.\n"
"Não é necessária conexão com a Internet após a configuração."

#: src/ui/welcome_wizard.rs
msgid "100% offline — your audio never leaves your device"
msgstr "100% offline — seu áudio nunca sai do dispositivo"

#: src/ui/welcome_wizard.rs
msgid "Supports 99 languages with auto-detection"
msgstr "Suporta 99 idiomas com detecção automática"

#: src/ui/welcome_wizard.rs
msgid "Download a Whisper Model"
msgstr "Baixar um modelo Whisper"

#: src/ui/welcome_wizard.rs
msgid ""
"A language model is needed for transcription.\n"
"We recommend starting with the Tiny model (~75 MB)."
msgstr ""
"Um modelo é necessário para a transcrição.\n"
"Recomendamos o modelo Tiny (~75 MB)."

#: src/ui/welcome_wizard.rs
msgid "Download Model"
msgstr "Baixar modelo"

#: src/ui/welcome_wizard.rs
msgid "Downloading…"
msgstr "Baixando…"

#: src/ui/welcome_wizard.rs
msgid "Retry"
msgstr "Tentar novamente"

#: src/ui/welcome_wizard.rs
msgid "You're All Set!"
msgstr "Tudo pronto!"

#: src/ui/welcome_wizard.rs
msgid "Download complete!"
msgstr "Download concluído!"

#. Settings — Language
#: src/ui/settings/language.rs
msgid "Language Detection"
msgstr "Detecção de idioma"

#: src/ui/settings/language.rs
msgid "Whisper can automatically detect the spoken language"
msgstr "O Whisper pode detectar automaticamente o idioma falado"

#: src/ui/settings/language.rs
msgid "Auto-detect Language"
msgstr "Detectar idioma automaticamente"

#: src/ui/settings/language.rs
msgid "Let Whisper determine the language automatically"
msgstr "Deixar o Whisper determinar o idioma automaticamente"

#: src/ui/settings/language.rs
msgid "Manual Selection"
msgstr "Seleção manual"

#: src/ui/settings/language.rs
msgid "Force a specific language for transcription"
msgstr "Forçar um idioma específico para a transcrição"

#: src/ui/settings/language.rs
msgid "Used when auto-detect is disabled"
msgstr "Usado quando a detecção automática está desativada"

#: src/ui/settings/language.rs
msgid "Supported Languages"
msgstr "Idiomas suportados"

#: src/ui/settings/language.rs
msgid "Translation"
msgstr "Tradução"

#: src/ui/settings/language.rs
msgid "Whisper can also translate speech to English"
msgstr "O Whisper também pode traduzir fala para inglês"

#. Settings — Microphone
#: src/ui/settings/microphone.rs
msgid "Input Device"
msgstr "Dispositivo de entrada"

#: src/ui/settings/microphone.rs
msgid "Select the microphone to use for recording"
msgstr "Selecione o microfone para gravação"

#: src/ui/settings/microphone.rs
msgid "Refresh device list"
msgstr "Atualizar lista de dispositivos"

#: src/ui/settings/microphone.rs
msgid "Audio Settings"
msgstr "Configurações de áudio"

#: src/ui/settings/microphone.rs
msgid "Sample Rate"
msgstr "Taxa de amostragem"

#: src/ui/settings/microphone.rs
msgid "Audio will be resampled to 16kHz for Whisper"
msgstr "O áudio será reamostrado para 16 kHz para o Whisper"

#: src/ui/settings/microphone.rs
msgid "Channels"
msgstr "Canais"

#: src/ui/settings/microphone.rs
msgid "Stereo input is automatically converted to mono"
msgstr "A entrada estéreo é convertida automaticamente para mono"

#: src/ui/settings/microphone.rs
msgid "Mono"
msgstr "Mono"

#: src/ui/settings/microphone.rs
msgid "Microphone Test"
msgstr "Teste de microfone"

#: src/ui/settings/microphone.rs
msgid "Test Microphone"
msgstr "Testar microfone"

#: src/ui/settings/microphone.rs
msgid "Record a short sample to verify your microphone works"
msgstr "Grave uma amostra curta para verificar seu microfone"

#: src/ui/settings/microphone.rs
msgid "Test"
msgstr "Testar"

#: src/ui/settings/microphone.rs
msgid "No audio input devices found"
msgstr "Nenhum dispositivo de áudio encontrado"

#: src/ui/settings/microphone.rs
msgid "Check that a microphone is connected"
msgstr "Verifique se um microfone está conectado"

#. Settings — Model
#: src/ui/settings/model.rs
msgid "Whisper Models"
msgstr "Modelos Whisper"

#: src/ui/settings/model.rs
msgid "Select a model. Larger models are more accurate but slower."
msgstr "Selecione um modelo. Os maiores são mais precisos, mas mais lentos."

#: src/ui/settings/model.rs
msgid "Downloaded"
msgstr "Baixado"

#: src/ui/settings/model.rs
msgid "Download"
msgstr "Baixar"

#: src/ui/settings/model.rs
