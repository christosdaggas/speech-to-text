#. Welcome wizard
#: src/ui/welcome_wizard.rs
msgid "Welcome to Speech to Text"
msgstr "Willkommen bei Sprache zu Text"

#: src/ui/welcome_wizard.rs
msgid "Next"
msgstr "Weiter"

#: src/ui/welcome_wizard.rs
msgid "Get Started"
msgstr "Loslegen"

#: src/ui/welcome_wizard.rs
msgid ""
"Convert speech to text locally on your machine.\n"
"No internet connection required after initial setup."
msgstr ""
"Konvertieren Sie Sprache lokal in Text.\n"
"Nach der Einrichtung ist keine Internetverbindung erforderlich."

#: src/ui/welcome_wizard.rs
msgid "100% offline — your audio never leaves your device"
msgstr "100 % offline — Ihr Audio verlässt nie Ihr Gerät"

#: src/ui/welcome_wizard.rs
msgid "Supports 99 languages with auto-detection"
msgstr "Unterstützt 99 Sprachen mit automatischer Erkennung"

#: src/ui/welcome_wizard.rs
msgid "Download a Whisper Model"
msgstr "Ein Whisper-Modell herunterladen"

#: src/ui/welcome_wizard.rs
msgid ""
"A language model is needed for transcription.\n"
"We recommend starting with the Tiny model (~75 MB)."
msgstr ""
"Ein Sprachmodell wird für die Transkription benötigt.\n"
"Wir empfehlen das Tiny-Modell (~75 MB)."

#: src/ui/welcome_wizard.rs
msgid "Download Model"
msgstr "Modell herunterladen"

#: src/ui/welcome_wizard.rs
msgid "Downloading…"
msgstr "Wird heruntergeladen…"

#: src/ui/welcome_wizard.rs
msgid "Retry"
msgstr "Erneut versuchen"

#: src/ui/welcome_wizard.rs
msgid "You're All Set!"
msgstr "Alles bereit!"

#: src/ui/welcome_wizard.rs
msgid "Download complete!"
msgstr "Download abgeschlossen!"

#. Settings — Language
#: src/ui/settings/language.rs
msgid "Language Detection"
msgstr "Spracherkennung"

#: src/ui/settings/language.rs
msgid "Whisper can automatically detect the spoken language"
msgstr "Whisper kann die gesprochene Sprache automatisch erkennen"

#: src/ui/settings/language.rs
msgid "Auto-detect Language"
msgstr "Sprache automatisch erkennen"

#: src/ui/settings/language.rs
msgid "Let Whisper determine the language automatically"
msgstr "Whisper die Sprache automatisch bestimmen lassen"

#: src/ui/settings/language.rs
msgid "Manual Selection"
msgstr "Manuelle Auswahl"

#: src/ui/settings/language.rs
msgid "Force a specific language for transcription"
msgstr "Eine bestimmte Sprache für die Transkription erzwingen"

#: src/ui/settings/language.rs
msgid "Used when auto-detect is disabled"
msgstr "Wird verwendet, wenn die Auto-Erkennung deaktiviert ist"

#: src/ui/settings/language.rs
msgid "Supported Languages"
msgstr "Unterstützte Sprachen"

#: src/ui/settings/language.rs
msgid "Translation"
msgstr "Übersetzung"

#: src/ui/settings/language.rs
msgid "Whisper can also translate speech to English"
msgstr "Whisper kann Sprache auch ins Englische übersetzen"

#. Settings — Microphone
#: src/ui/settings/microphone.rs
msgid "Input Device"
msgstr "Eingabegerät"

#: src/ui/settings/microphone.rs
msgid "Select the microphone to use for recording"
msgstr "Mikrofon für die Aufnahme auswählen"

#: src/ui/settings/microphone.rs
msgid "Refresh device list"
msgstr "Geräteliste aktualisieren"

#: src/ui/settings/microphone.rs
msgid "Audio Settings"
msgstr "Audio-Einstellungen"

#: src/ui/settings/microphone.rs
msgid "Sample Rate"
msgstr "Abtastrate"

#: src/ui/settings/microphone.rs
msgid "Audio will be resampled to 16kHz for Whisper"
msgstr "Audio wird für Whisper auf 16 kHz umgewandelt"

#: src/ui/settings/microphone.rs
msgid "Channels"
msgstr "Kanäle"

#: src/ui/settings/microphone.rs
msgid "Stereo input is automatically converted to mono"
msgstr "Stereo-Eingang wird automatisch in Mono konvertiert"

#: src/ui/settings/microphone.rs
msgid "Mono"
msgstr "Mono"

#: src/ui/settings/microphone.rs
msgid "Microphone Test"
msgstr "Mikrofontest"

#: src/ui/settings/microphone.rs
msgid "Test Microphone"
msgstr "Mikrofon testen"

#: src/ui/settings/microphone.rs
msgid "Record a short sample to verify your microphone works"
msgstr "Nehmen Sie eine kurze Probe auf, um Ihr Mikrofon zu testen"

#: src/ui/settings/microphone.rs
msgid "Test"
msgstr "Testen"

#: src/ui/settings/microphone.rs
msgid "No audio input devices found"
msgstr "Keine Audio-Eingabegeräte gefunden"

#: src/ui/settings/microphone.rs
msgid "Check that a microphone is connected"
msgstr "Prüfen Sie, ob ein Mikrofon angeschlossen ist"

#. Settings — Model
#: src/ui/settings/model.rs
msgid "Whisper Models"
msgstr "Whisper-Modelle"

#: src/ui/settings/model.rs
msgid "Select a model. Larger models are more accurate but slower."
msgstr "Wählen Sie ein Modell. Größere Modelle sind genauer, aber langsamer."

#: src/ui/settings/model.rs
msgid "Downloaded"
msgstr "Heruntergeladen"

#: src/ui/settings/model.rs
msgid "Download"
msgstr "Herunterladen"

#: src/ui/settings/model.rs
msgid "Download Progress"
msgstr "Download-Fortschritt"

#: src/ui/settings/model.rs
msgid "No download in progress"
msgstr "Kein Download aktiv"

#: src/ui/settings/model.rs
msgid "Storage"
msgstr "Speicher"

#: src/ui/settings/model.rs
msgid "Choose where Whisper models are stored."
msgstr "Wählen Sie den Speicherort für Whisper-Modelle."

#: src/ui/settings/model.rs
msgid "Models Directory"
msgstr "Modellverzeichnis"

#: src/ui/settings/model.rs
msgid "Open in file manager"
msgstr "Im Dateimanager öffnen"

#: src/ui/settings/model.rs
msgid "Change models directory"
msgstr "Modellverzeichnis ändern"

#: src/ui/settings/model.rs
msgid "Select Models Directory"
msgstr "Modellverzeichnis auswählen"

#: src/ui/settings/model.rs
msgid "Reset to default location"
msgstr "Auf Standardort zurücksetzen"

#. Settings — Performance
#: src/ui/settings/performance.rs
msgid "GPU Acceleration"
msgstr "GPU-Beschleunigung"

#: src/ui/settings/performance.rs
msgid ""
"Use GPU for faster transcription when available. Requires CUDA or OpenCL "
"support."
msgstr ""
"GPU für schnellere Transkription verwenden. Erfordert CUDA oder OpenCL."

#: src/ui/settings/performance.rs
msgid "Use GPU"
msgstr "GPU verwenden"

#: src/ui/settings/performance.rs
msgid "Accelerate transcription with your graphics card"
msgstr "Transkription mit der Grafikkarte beschleunigen"

#: src/ui/settings/performance.rs
msgid "CPU Fallback"
msgstr "CPU-Rückfall"

#: src/ui/settings/performance.rs
msgid "Automatically fall back to CPU if GPU is unavailable"
msgstr "Automatisch auf CPU zurückfallen, wenn GPU nicht verfügbar"

#: src/ui/settings/performance.rs
msgid "GPU Status"
msgstr "GPU-Status"

#: src/ui/settings/performance.rs
msgid "CPU Settings"
msgstr "CPU-Einstellungen"

#: src/ui/settings/performance.rs
msgid "Worker Threads"
msgstr "Arbeitsthreads"

#: src/ui/settings/performance.rs
msgid "Number of CPU threads for transcription"
msgstr "Anzahl der CPU-Threads für die Transkription"

#: src/ui/settings/performance.rs
msgid "Memory"
msgstr "Speicher"

#: src/ui/settings/performance.rs
msgid "Estimated Memory Usage"
msgstr "Geschätzter Speicherverbrauch"

#: src/ui/settings/performance.rs
msgid "Depends on the selected model size"
msgstr "Hängt von der gewählten Modellgröße ab"

#: src/ui/settings/performance.rs
msgid "Beam Size"
msgstr "Beam-Größe"

#: src/ui/settings/performance.rs
msgid "Higher values improve accuracy but use more memory"
msgstr ""
"Höhere Werte verbessern die Genauigkeit, verbrauchen aber mehr Speicher"

