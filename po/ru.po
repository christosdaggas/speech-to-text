#. Welcome wizard
#: src/ui/welcome_wizard.rs
msgid "Welcome to Speech to Text"
msgstr "Добро пожаловать в Речь в текст"

#: src/ui/welcome_wizard.rs
msgid "Next"
msgstr "Далее"

#: src/ui/welcome_wizard.rs
msgid "Get Started"
msgstr "Начать"

#: src/ui/welcome_wizard.rs
msgid ""
"Convert speech to text locally on your machine.\n"
"No internet connection required after initial setup."
msgstr ""
"Преобразуйте речь в текст локально.\n"
"Подключение к Интернету не требуется после настройки."

#: src/ui/welcome_wizard.rs
msgid "100% offline — your audio never leaves your device"
msgstr "100% автономно — ваш звук никогда не покидает устройство"

#: src/ui/welcome_wizard.rs
msgid "Supports 99 languages with auto-detection"
msgstr "Поддержка 99 языков с автоопределением"

#: src/ui/welcome_wizard.rs
msgid "Download a Whisper Model"
msgstr "Скачать модель Whisper"

#: src/ui/welcome_wizard.rs
msgid ""
"A language model is needed for transcription.\n"
"We recommend starting with the Tiny model (~75 MB)."
msgstr ""
"Для транскрипции нужна модель.\n"
"Рекомендуем начать с модели Tiny (~75 МБ)."

#: src/ui/welcome_wizard.rs
msgid "Download Model"
msgstr "Скачать модель"

#: src/ui/welcome_wizard.rs
msgid "Downloading…"
msgstr "Загрузка…"

#: src/ui/welcome_wizard.rs
msgid "Retry"
msgstr "Повторить"

#: src/ui/welcome_wizard.rs
msgid "You're All Set!"
msgstr "Всё готово!"

#: src/ui/welcome_wizard.rs
msgid "Download complete!"
msgstr "Загрузка завершена!"

#. Settings — Language
#: src/ui/settings/language.rs
msgid "Language Detection"
msgstr "Определение языка"

#: src/ui/settings/language.rs
msgid "Whisper can automatically detect the spoken language"
msgstr "Whisper может автоматически определять язык"

#: src/ui/settings/language.rs
msgid "Auto-detect Language"
msgstr "Автоопределение языка"

#: src/ui/settings/language.rs
msgid "Let Whisper determine the language automatically"
msgstr "Позвольте Whisper определить язык автоматически"

#: src/ui/settings/language.rs
msgid "Manual Selection"
msgstr "Ручной выбор"

#: src/ui/settings/language.rs
msgid "Force a specific language for transcription"
msgstr "Принудительно задать язык для транскрипции"

#: src/ui/settings/language.rs
msgid "Used when auto-detect is disabled"
msgstr "Используется при отключённом автоопределении"

#: src/ui/settings/language.rs
msgid "Supported Languages"
msgstr "Поддерживаемые языки"

#: src/ui/settings/language.rs
msgid "Translation"
msgstr "Перевод"

#: src/ui/settings/language.rs
msgid "Whisper can also translate speech to English"
msgstr "Whisper также может переводить речь на английский"

#. Settings — Microphone
#: src/ui/settings/microphone.rs
msgid "Input Device"
msgstr "Устройство ввода"

#: src/ui/settings/microphone.rs
msgid "Select the microphone to use for recording"
msgstr "Выберите микрофон для записи"

#: src/ui/settings/microphone.rs
msgid "Refresh device list"
msgstr "Обновить список устройств"

#: src/ui/settings/microphone.rs
msgid "Audio Settings"
msgstr "Настройки звука"

#: src/ui/settings/microphone.rs
msgid "Sample Rate"
msgstr "Частота дискретизации"

#: src/ui/settings/microphone.rs
msgid "Audio will be resampled to 16kHz for Whisper"
msgstr "Звук будет преобразован в 16 кГц для Whisper"

#: src/ui/settings/microphone.rs
msgid "Channels"
msgstr "Каналы"

#: src/ui/settings/microphone.rs
msgid "Stereo input is automatically converted to mono"
msgstr "Стереовход автоматически преобразуется в моно"

#: src/ui/settings/microphone.rs
msgid "Mono"
msgstr "Моно"

#: src/ui/settings/microphone.rs
msgid "Microphone Test"
msgstr "Проверка микрофона"

#: src/ui/settings/microphone.rs
msgid "Test Microphone"
msgstr "Проверить микрофон"

#: src/ui/settings/microphone.rs
msgid "Record a short sample to verify your microphone works"
msgstr "Запишите короткий образец для проверки микрофона"

#: src/ui/settings/microphone.rs
msgid "Test"
msgstr "Проверить"

#: src/ui/settings/microphone.rs
msgid "No audio input devices found"
msgstr "Устройства ввода звука не найдены"

#: src/ui/settings/microphone.rs
msgid "Check that a microphone is connected"
msgstr "Проверьте подключение микрофона"

#. Settings — Model
#: src/ui/settings/model.rs
msgid "Whisper Models"
msgstr "Модели Whisper"

#: src/ui/settings/model.rs
msgid "Select a model. Larger models are more accurate but slower."
msgstr "Выберите модель. Большие модели точнее, но медленнее."

#: src/ui/settings/model.rs
msgid "Downloaded"
msgstr "Скачано"

#: src/ui/settings/model.rs
msgid "Download"
msgstr "Скачать"

#: src/ui/settings/model.rs
msgid "Download Progress"
msgstr "Прогресс загрузки"

#: src/ui/settings/model.rs
msgid "No download in progress"
msgstr "Нет активных загрузок"

#: src/ui/settings/model.rs
msgid "Storage"
msgstr "Хранилище"

#: src/ui/settings/model.rs
msgid "Choose where Whisper models are stored."
msgstr "Выберите место хранения моделей Whisper."

#: src/ui/settings/model.rs
msgid "Models Directory"
msgstr "Каталог моделей"

#: src/ui/settings/model.rs
msgid "Open in file manager"
msgstr "Открыть в файловом менеджере"

#: src/ui/settings/model.rs
msgid "Change models directory"
msgstr "Изменить каталог моделей"

#: src/ui/settings/model.rs
msgid "Select Models Directory"
msgstr "Выбрать каталог моделей"

#: src/ui/settings/model.rs
msgid "Reset to default location"
msgstr "Сбросить расположение по умолчанию"

#. Settings — Performance
#: src/ui/settings/performance.rs
msgid "GPU Acceleration"
msgstr "Ускорение GPU"

#: src/ui/settings/performance.rs
msgid ""
"Use GPU for faster transcription when available. Requires CUDA or OpenCL "
"support."
msgstr "Использовать GPU для ускорения. Требуется CUDA или OpenCL."

#: src/ui/settings/performance.rs
msgid "Use GPU"
msgstr "Использовать GPU"

#: src/ui/settings/performance.rs
msgid "Accelerate transcription with your graphics card"
msgstr "Ускорить транскрипцию с помощью видеокарты"

#: src/ui/settings/performance.rs
msgid "CPU Fallback"
msgstr "Резерв ЦП"

#: src/ui/settings/performance.rs
msgid "Automatically fall back to CPU if GPU is unavailable"
msgstr "Автоматический переход на ЦП при недоступности GPU"

#: src/ui/settings/performance.rs
msgid "GPU Status"
msgstr "Статус GPU"

#: src/ui/settings/performance.rs
msgid "CPU Settings"
msgstr "Настройки ЦП"

#: src/ui/settings/performance.rs
msgid "Worker Threads"
msgstr "Рабочие потоки"

#: src/ui/settings/performance.rs
msgid "Number of CPU threads for transcription"
msgstr "Количество потоков ЦП для транскрипции"

#: src/ui/settings/performance.rs
msgid "Memory"
msgstr "Память"

#: src/ui/settings/performance.rs
msgid "Estimated Memory Usage"
msgstr "Оценка использования памяти"

#: src/ui/settings/performance.rs
msgid "Depends on the selected model size"
msgstr "Зависит от выбранного размера модели"

#: src/ui/settings/performance.rs
msgid "Beam Size"
msgstr "Размер луча"

#: src/ui/settings/performance.rs
msgid "Higher values improve accuracy but use more memory"
msgstr "Более высокие значения повышают точность, но требуют больше памяти"

